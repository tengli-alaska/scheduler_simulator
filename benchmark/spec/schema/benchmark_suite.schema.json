{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheduler-simulator.local/schema/benchmark_suite.schema.json",
  "title": "Scheduler Simulator Benchmark Suite",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_version",
    "suite_id",
    "title",
    "description",
    "defaults",
    "experiments"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "suite.v1"
    },
    "benchmark_version": {
      "type": "string",
      "minLength": 1
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "required": ["scheduler", "replications", "topology", "seed_base"],
      "properties": {
        "scheduler": { "type": "string" },
        "replications": { "type": "integer", "minimum": 1 },
        "topology": { "type": "string", "enum": ["sq", "mq"] },
        "seed_base": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "experiments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "objective", "runs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "reuse_from_experiment": { "type": "string" },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["workload", "cores", "num_tasks", "stop_time", "topology"],
              "properties": {
                "workload": { "type": "string" },
                "cores": { "type": "integer", "minimum": 1 },
                "num_tasks": { "type": "integer", "minimum": 1 },
                "stop_time": { "type": "number", "exclusiveMinimum": 0 },
                "topology": { "type": "string", "enum": ["sq", "mq"] },
                "balancer": { "type": "string", "enum": ["rr", "leastloaded"] },
                "work_stealing": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
